[
 {
  "doctype": "Custom Field",
  "name": "Task-custom_span_section",
  "dt": "Task",
  "module": "PM",
  "fieldname": "custom_span_section",
  "label": "Span",
  "fieldtype": "Section Break",
  "insert_after": "status",
  "collapsible": 0
 },
 {
  "doctype": "Custom Field",
  "name": "Task-custom_work_type",
  "dt": "Task",
  "module": "PM",
  "fieldname": "custom_work_type",
  "label": "Work Type",
  "fieldtype": "Select",
  "options": "Phase\nStep\nEpic\nStory\nTask\nBug",
  "default": "Task",
  "insert_after": "custom_span_section",
  "in_standard_filter": 1,
  "in_list_view": 1,
  "allow_in_quick_entry": 1,
  "description": "Type, geen niveau. Phase en Epic worden group-tasks."
 },
 {
  "doctype": "Custom Field",
  "name": "Task-custom_board_state",
  "dt": "Task",
  "module": "PM",
  "fieldname": "custom_board_state",
  "label": "Board State",
  "fieldtype": "Select",
  "options": "Backlog\nTodo\nIn Progress\nIn Review\nDone\nCanceled",
  "default": "Backlog",
  "insert_after": "custom_work_type",
  "in_standard_filter": 1,
  "allow_in_quick_entry": 1,
  "description": "Stuurt de kanban en synct eenrichtings naar native status."
 },
 {
  "doctype": "Custom Field",
  "name": "Task-custom_story_points",
  "dt": "Task",
  "module": "PM",
  "fieldname": "custom_story_points",
  "label": "Story Points",
  "fieldtype": "Int",
  "insert_after": "custom_board_state",
  "non_negative": 1,
  "allow_in_quick_entry": 1,
  "description": "Optionele schatting."
 },
 {
  "doctype": "Custom Field",
  "name": "Task-custom_discipline",
  "dt": "Task",
  "module": "PM",
  "fieldname": "custom_discipline",
  "label": "Discipline",
  "fieldtype": "Table MultiSelect",
  "options": "Span Task Discipline",
  "insert_after": "custom_story_points",
  "in_standard_filter": 1,
  "allow_in_quick_entry": 1,
  "description": "Cross-cutting disciplines (Frontend, Backend, ...). Meerdere toegestaan."
 },
 {
  "doctype": "Custom Field",
  "name": "Task-custom_phase",
  "dt": "Task",
  "module": "PM",
  "fieldname": "custom_phase",
  "label": "Phase (auto)",
  "fieldtype": "Link",
  "options": "Task",
  "insert_after": "custom_discipline",
  "read_only": 1,
  "in_standard_filter": 1,
  "description": "Dichtstbijzijnde Phase-voorouder. Automatisch gevuld; voor plat filteren op fase + alle children."
 },
 {
  "doctype": "Custom Field",
  "name": "Task-custom_epic",
  "dt": "Task",
  "module": "PM",
  "fieldname": "custom_epic",
  "label": "Epic (auto)",
  "fieldtype": "Link",
  "options": "Task",
  "insert_after": "custom_phase",
  "read_only": 1,
  "in_standard_filter": 1,
  "description": "Dichtstbijzijnde Epic-voorouder. Automatisch gevuld; voor plat filteren op epic + bijbehorende stories."
 },
 {
  "doctype": "Custom Field",
  "name": "Task-custom_span_section_end",
  "dt": "Task",
  "module": "PM",
  "fieldname": "custom_span_section_end",
  "label": "",
  "fieldtype": "Section Break",
  "insert_after": "custom_epic",
  "collapsible": 0
 }
]
